# bili_unit — environment variables (copy to .env and fill in)
#
# This file lists all configurable knobs read by bili_unit.fetching.env and
# bili_unit.processing.env via pydantic-settings. Anything not set here
# falls back to the in-code default.
#
# DO NOT commit .env. Real credentials must never enter version control.

# ---------------------------------------------------------------------------
# Bilibili credentials (run `python -m bili_unit login` to obtain)
# ---------------------------------------------------------------------------
BILI_SESSDATA=
BILI_JCT=
BILI_BUVID3=
BILI_BUVID4=
BILI_DEDEUSERID=
BILI_AC_TIME_VALUE=

# ---------------------------------------------------------------------------
# Storage paths (default to cwd-relative; override to relocate)
# ---------------------------------------------------------------------------
# BILI_DB_DIR=output/bili
# BILI_PROCESSING_TEMP_DIR=output/bili/asr/temp
# BILI_PROCESSING_ASR_CACHE_DIR=output/bili/asr/cache

# ---------------------------------------------------------------------------
# Fetching tunables
# ---------------------------------------------------------------------------
# BILI_FETCHING_HTTP_BACKEND=aiohttp        # or curl_cffi (requires extra)
# BILI_FETCHING_IMPERSONATE=chrome131
# BILI_FETCHING_GLOBAL_QPS=1.0
# BILI_FETCHING_ENDPOINT_QPS=0.5
# BILI_FETCHING_REQUEST_TIMEOUT=30
# BILI_FETCHING_MAX_RETRIES=3
# BILI_FETCHING_VIDEO_DETAIL_QPS=0.5
# BILI_FETCHING_RECOVERY_COOLDOWN=300
# BILI_FETCHING_ITEM_CONCURRENCY=3
# BILI_FETCHING_REFRESH_AFTER_DAYS=7
# BILI_FETCHING_STALE_RUNNING_THRESHOLD_SECONDS=900   # issue #3: RUNNING task with updated_at older than this is taken over

# ---------------------------------------------------------------------------
# Processing — ASR / audio
# ---------------------------------------------------------------------------
# Recommended: run `python -m bili_unit init-mimo` once to populate this
# section interactively. Manual edits below also work.
#
# Backend selection (CLI override: `asr -b mock` for one-off runs):
BILI_PROCESSING_ASR_BACKEND=mimo                 # mimo | mock
#
# MiMo profile — selects base URL; you do not need to remember hosts:
#   token_plan_cn   https://token-plan-cn.xiaomimimo.com/v1   (默认；tp-* keys)
#   token_plan_sgp  https://token-plan-sgp.xiaomimimo.com/v1
#   token_plan_ams  https://token-plan-ams.xiaomimimo.com/v1
#   pay_as_you_go   https://api.xiaomimimo.com/v1             (按量付费 sk-* keys)
#   custom          uses BILI_PROCESSING_ASR_BASE_URL below   (中转站 / 自建)
BILI_PROCESSING_ASR_PROFILE=token_plan_cn
#
# Auth style — official endpoints accept either; relays usually need bearer.
BILI_PROCESSING_ASR_AUTH_STYLE=api_key            # api_key | bearer
#
# API key — tp-* / sk-* / relay-issued. Required when backend=mimo.
BILI_PROCESSING_ASR_API_KEY=
#
# Custom base URL — only consulted when ASR_PROFILE=custom.
# BILI_PROCESSING_ASR_BASE_URL=https://my-relay.example.com/v1
#
# BILI_PROCESSING_ASR_MODEL=mimo-v2.5-asr
# BILI_PROCESSING_ASR_LANGUAGE=auto
# BILI_PROCESSING_ASR_TIMEOUT=300
# BILI_PROCESSING_ASR_MAX_FILE_SIZE_MB=10
# BILI_PROCESSING_ASR_MAX_INPUT_TOKENS=5400
# BILI_PROCESSING_ASR_TOKENS_PER_SECOND=6.5
# BILI_PROCESSING_ASR_MAX_COMPLETION_TOKENS=1024
# BILI_PROCESSING_ASR_MAX_SEGMENT_SECONDS=120
# BILI_PROCESSING_ASR_HIGH_RISK_SPLIT_ENABLED=true
# BILI_PROCESSING_ASR_HIGH_RISK_SPLIT_SECONDS=30
# BILI_PROCESSING_ASR_HIGH_RISK_MIN_SEGMENT_SECONDS=10
# BILI_PROCESSING_ASR_EMPTY_SEGMENT_SKIP_SECONDS=5

# ---------------------------------------------------------------------------
# Processing — retry / ffmpeg
# ---------------------------------------------------------------------------
# BILI_PROCESSING_MAX_RETRIES=3
# BILI_PROCESSING_RETRY_DELAYS=30,60,120
# BILI_PROCESSING_FFMPEG_PATH=auto            # auto | system | imageio | <path>
# BILI_PROCESSING_AUDIO_MAX_SEGMENT_MINUTES=15
